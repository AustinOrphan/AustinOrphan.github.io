---
interface PostLink {
  title: string;
  id: string;
}

interface Props {
  prevPost?: PostLink;
  nextPost?: PostLink;
}

const { prevPost, nextPost } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="blog-footer">
  <div class="blog-footer-inner">
    {(prevPost || nextPost) && (
      <nav class="blog-footer-nav">
        {prevPost ? (
          <a href={`/blog/${prevPost.id}/`} class="blog-footer-prev">
            <span class="blog-footer-nav-label">← Previous</span>
            <span class="blog-footer-nav-title">{prevPost.title}</span>
          </a>
        ) : <span />}
        {nextPost ? (
          <a href={`/blog/${nextPost.id}/`} class="blog-footer-next">
            <span class="blog-footer-nav-label">Next →</span>
            <span class="blog-footer-nav-title">{nextPost.title}</span>
          </a>
        ) : <span />}
      </nav>
    )}
    <div class="blog-footer-social">
      <a href="https://github.com/austinorphan" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <i class="ph-duotone ph-github-logo"></i>
      </a>
      <a href="https://www.linkedin.com/in/austinorphan/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <i class="ph-duotone ph-linkedin-logo"></i>
      </a>
      <a href="mailto:AustinGOrphan@gmail.com" aria-label="Email">
        <i class="ph-duotone ph-envelope-simple"></i>
      </a>
    </div>
    <p class="blog-footer-copy">© {year} Austin Orphan</p>
  </div>
</footer>
